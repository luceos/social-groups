{
    "name": "ernestdefoe/social-groups",
    "description": "Social groups for Flarum 2 — members can create, join, and manage groups.",
    "type": "flarum-extension",
    "keywords": ["flarum", "social", "groups", "community"],
    "homepage": "https://github.com/ernestdefoe/social-groups",
    "license": "MIT",
    "authors": [
        {
            "name": "Ernestdefoe",
            "email": "ernestdefoe@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "flarum/core": "^2.0"
    },
    "suggest": {
        "fof/upload": "^2.0 — required for file/image attachments in group posts (the attach button in the post composer calls /api/fof/upload)"
    },
    "autoload": {
        "psr-4": {
            "Ernestdefoe\\SocialGroups\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Social Groups",
            "category": "feature",
            "icon": {
                "name": "fa-solid fa-users",
                "backgroundColor": "#4A90E2",
                "color": "#fff"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
