{
    "name": "ernestdefoe/social-groups",
    "description": "Social groups for Flarum 2 — members can create, join, and manage groups.",
    "keywords": ["flarum", "social", "groups", "community"],
    "homepage": "https://github.com/ernestdefoe/social-groups",
    "license": "MIT",
    "authors": [
        {
            "name": "Ernestdefoe",
            "email": "ernestdefoe@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "flarum/core": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ernestdefoe\\SocialGroups\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Social Groups",
            "category": "feature",
            "icon": {
                "name": "fas fa-users",
                "backgroundColor": "#4A90E2",
                "color": "#fff"
            }
        }
    },
    "config": {
        "sort-packages": true
    }
}
